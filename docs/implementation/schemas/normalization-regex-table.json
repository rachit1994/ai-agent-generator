{
  "schema_version": "1.0.0",
  "description": "Applied in order; first match wins. Bump version only with EM + Data/Memory DRI + Safety Owner sign-off.",
  "replacements": [
    {
      "token": "{{uuid}}",
      "pattern": "[0-9a-f]{8}-[0-9a-f]{4}-[1-5][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}",
      "flags": "gi"
    },
    {
      "token": "{{sha}}",
      "pattern": "\\b[0-9a-f]{40}\\b",
      "flags": "gi"
    },
    {
      "token": "{{path}}",
      "pattern": "(?:/|[A-Za-z]:\\\\)[^\\s]+",
      "flags": "g"
    },
    {
      "token": "{{num}}",
      "pattern": "\\b\\d+(?:\\.\\d+)?\\b",
      "flags": "g"
    }
  ]
}
